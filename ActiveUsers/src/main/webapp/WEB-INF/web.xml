<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
         xmlns="http://java.sun.com/xml/ns/javaee" 
         xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd" 
         version="2.5">
  
  <display-name>ActiveUsers</display-name>
  
  <description>
    Веб-приложение для отслеживания активных пользователей с использованием
    HttpSessionListener, ServletContextListener и Filter
  </description>
  
  <!-- Конфигурация сессии -->
  <session-config>
    <session-timeout>30</session-timeout>
  </session-config>
  
  <!-- Welcome file -->
  <welcome-file-list>
    <welcome-file>index.html</welcome-file>
    <welcome-file>users.jsp</welcome-file>
  </welcome-file-list>
  
  <!-- Listener для подсчёта активных сессий -->
  <listener>
    <listener-class>listener.ActiveUsersListener</listener-class>
  </listener>
  
  <!-- Listener для подсчёта总 пользователей -->
  <listener>
    <listener-class>listener.AppContextListener</listener-class>
  </listener>
  
  <!-- Filter для логирования запросов -->
  <filter>
    <filter-name>LoggingFilter</filter-name>
    <filter-class>filter.LoggingFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>LoggingFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>
</web-app>
